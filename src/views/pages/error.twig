{#
| Variable      | Type   | Description           |
|---------------|--------|-----------------------|
| error.code    | int    | HTTP error code       |
| error.message | string | Error message         |
#}
{% extends "layouts.master" %}

{% block content %}
<div class="container flex flex-col items-center justify-center min-h-[60vh] py-20 text-center">

    <div class="mb-8">
        <span class="text-8xl font-black text-souq-primary opacity-20">{{ error.code ?? '404' }}</span>
    </div>

    <i class="sicon-search-find text-6xl text-gray-300 mb-6"></i>

    <h1 class="text-2xl font-bold text-souq-text mb-3">
        {{ trans('common.errors.404') }}
    </h1>

    <p class="text-souq-text-muted mb-8 max-w-md">
        {{ error.message ?? trans('common.errors.404') }}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <salla-button href="{{ link('/') }}" color="primary" class="btn--rounded-full">
            <i class="sicon-home-2 rtl:ml-2 ltr:mr-2"></i>
            {{ trans('common.elements.back_home') }}
        </salla-button>

        <salla-button href="{{ link('/') }}" shape="outlined" color="primary" class="btn--rounded-full"
                      onclick="history.back(); return false;">
            {{ trans('common.titles.support') }}
        </salla-button>
    </div>

</div>
{% endblock %}
