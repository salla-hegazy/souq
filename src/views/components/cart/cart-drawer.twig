{#
 SOUQ Cart Drawer
 — Alpine UI store toggles visibility via cart:opened / cart:closed events
 — GSAP (GsapAnimator.initCartDrawer) animates the slide
 — Salla SDK handles all cart mutations
#}
{% set free_ship_threshold = theme.settings.get('free_shipping_amount', 0)|number_format(0) %}

{# Overlay #}
<div class="souq-cart-overlay fixed inset-0 bg-black/50 z-[300] invisible opacity-0"
     @click="$store.ui.closeCart()"
     aria-hidden="true"></div>

{# Drawer panel #}
<aside class="souq-cart-drawer fixed top-0 end-0 h-full w-full max-w-sm bg-white z-[400] invisible flex flex-col shadow-xl"
       role="dialog"
       aria-modal="true"
       aria-label="{{ trans('blocks.header.cart') }}"
       x-trap.noscroll="$store.ui.cartOpen">

  {# Header #}
  <div class="flex items-center justify-between px-5 py-4 border-b border-souq-border">
    <h2 class="text-lg font-semibold text-souq-text">
      {{ trans('blocks.header.cart') }}
      <span class="ms-1 text-sm text-souq-text-muted" x-text="`(${$store.cart?.count ?? 0})`"></span>
    </h2>
    <button @click="$store.ui.closeCart()"
            class="p-2 rounded-lg hover:bg-gray-100 transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-souq-primary focus:ring-offset-2"
            aria-label="{{ trans('common.close') }}">
      <i class="sicon-times text-xl text-souq-text-muted"></i>
    </button>
  </div>

  {# Free shipping progress #}
  {% if free_ship_threshold > 0 %}
    <div class="px-5 py-3 border-b border-souq-border bg-souq-bg"
         x-data="{ threshold: {{ free_ship_threshold }} }"
         x-show="$store.cart?.subtotal < threshold">
      <p class="text-xs text-souq-text-muted mb-1.5">
        {{ trans('pages.cart.free_shipping_remaining', { amount: '' }) }}
        <strong class="text-souq-primary" x-text="salla.money(threshold - ($store.cart?.subtotal ?? 0))"></strong>
      </p>
      <div class="h-1.5 bg-gray-200 rounded-full overflow-hidden">
        <div class="h-full bg-souq-primary rounded-full transition-all duration-500"
             :style="`width: ${Math.min(100, (($store.cart?.subtotal ?? 0) / threshold) * 100)}%`"></div>
      </div>
    </div>
    <div class="px-5 py-3 border-b border-souq-border bg-green-50 text-green-700 text-xs font-medium flex items-center gap-2"
         x-show="$store.cart?.subtotal >= threshold" x-cloak>
      <i class="sicon-check-circle"></i>
      {{ trans('pages.cart.free_shipping') }}
    </div>
  {% endif %}

  {# Cart items #}
  <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4">

    {# Empty state #}
    <div x-show="!$store.cart?.count" x-cloak class="flex flex-col items-center justify-center h-full text-center py-16">
      <i class="sicon-shopping-bag text-5xl text-gray-300 mb-4"></i>
      <p class="font-medium text-souq-text">{{ trans('pages.cart.empty_cart') }}</p>
      <p class="text-sm text-souq-text-muted mt-1 mb-6">{{ trans('pages.cart.empty_cart_sub') }}</p>
      <button @click="$store.ui.closeCart()"
              class="btn btn-primary rounded-full px-6 py-2.5 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-souq-primary focus:ring-offset-2">
        {{ trans('pages.cart.continue_shopping') }}
      </button>
    </div>

    {# Items list (real items rendered by Salla SDK — cart-summary component handles this) #}
    <salla-cart-summary layout="list" class="souq-cart-items-list"></salla-cart-summary>

  </div>

  {# Footer: coupon + checkout #}
  <div class="border-t border-souq-border px-5 py-5 space-y-4" x-show="$store.cart?.count" x-cloak>

    {# Coupon #}
    {% if store.settings.cart.apply_coupon_enabled %}
      <div x-data="{ coupon: '', applying: false, applied: false }"
           class="flex gap-2">
        <input type="text"
               x-model="coupon"
               :disabled="applied || applying"
               placeholder="{{ trans('pages.cart.coupon_placeholder') }}"
               class="flex-1 border border-souq-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-souq-primary">
        <button @click="
                  if (!coupon.trim()) return;
                  applying = true;
                  window.__cart.applyCoupon(coupon).then(() => { applied = true; }).finally(() => applying = false);
                "
                :disabled="applied || applying || !coupon.trim()"
                class="btn btn-outline btn-sm px-4 rounded-lg disabled:opacity-50 focus:outline-none focus:ring-2 focus:ring-souq-primary focus:ring-offset-2">
          <span x-show="!applying">{{ trans('pages.cart.apply_coupon') }}</span>
          <span x-show="applying" x-cloak><i class="sicon-refresh animate-spin"></i></span>
        </button>
      </div>
    {% endif %}

    {# Subtotal + checkout #}
    <div class="flex items-center justify-between text-sm text-souq-text-muted mb-2">
      <span>{{ trans('pages.cart.subtotal') }}</span>
      <strong class="text-souq-text text-base" x-text="salla.money($store.cart?.subtotal ?? 0)"></strong>
    </div>

    <a href="{{ store.url }}/cart"
       class="btn btn-primary w-full rounded-full py-3 text-base font-semibold flex items-center justify-center gap-2 focus:outline-none focus:ring-2 focus:ring-souq-primary focus:ring-offset-2">
      {{ trans('pages.cart.checkout') }}
      <i class="sicon-arrow-{{ theme.is_rtl ? 'left' : 'right' }} text-sm"></i>
    </a>

  </div>

</aside>
