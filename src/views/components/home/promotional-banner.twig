{# Promotional full-width banner #}
{% set banner_image = theme.settings.get('promo_banner_image') %}
{% set banner_title = theme.settings.get('promo_banner_title') %}
{% set banner_sub   = theme.settings.get('promo_banner_subtitle') %}
{% set banner_url   = theme.settings.get('promo_banner_url', store.url) %}
{% set banner_cta   = theme.settings.get('promo_banner_cta', trans('home.shop_now')) %}

{% if banner_image or banner_title %}
<section class="promo-banner py-8" data-animate>
  <div class="container">
    <a href="{{ banner_url }}"
       class="promo-banner__card relative flex items-center justify-center min-h-[240px] md:min-h-[320px] rounded-2xl overflow-hidden group bg-souq-secondary">

      {% if banner_image %}
        <img src="{{ banner_image }}" alt="{{ banner_title }}"
             class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
             loading="lazy">
        <div class="absolute inset-0 bg-gradient-to-t from-souq-secondary/70 via-transparent to-transparent"></div>
      {% endif %}

      <div class="relative z-10 text-center text-white px-6 py-8">
        {% if banner_title %}
          <h2 class="text-3xl md:text-4xl font-bold mb-3">{{ banner_title }}</h2>
        {% endif %}
        {% if banner_sub %}
          <p class="text-white/80 mb-6 text-lg">{{ banner_sub }}</p>
        {% endif %}
        <span class="btn btn-primary rounded-full px-8 py-3 font-semibold inline-flex items-center gap-2">
          {{ banner_cta }}
          <i class="sicon-arrow-{{ theme.is_rtl ? 'left' : 'right' }} text-sm"></i>
        </span>
      </div>

    </a>
  </div>
</section>
{% endif %}
