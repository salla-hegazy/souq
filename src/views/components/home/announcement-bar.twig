{% set msg = theme.settings.get('announcement_text') %}
{% if msg %}
<div id="announcement-bar" class="announcement-bar bg-primary text-white text-center py-2 px-4 text-sm relative">
  <span>{{ msg }}</span>
  <button onclick="document.getElementById('announcement-bar').remove()"
          class="absolute end-3 top-1/2 -translate-y-1/2 opacity-70 hover:opacity-100 transition-opacity"
          aria-label="{{ trans('common.close') }}">
    <i class="sicon-times text-xs"></i>
  </button>
</div>
{% endif %}
