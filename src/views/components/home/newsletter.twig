{# Newsletter subscription section #}
<section class="newsletter-section relative overflow-hidden py-20" data-animate>

  <div class="absolute inset-0 bg-primary opacity-95"></div>
  <div class="pointer-events-none absolute -top-20 -start-20 w-80 h-80 rounded-full bg-white opacity-5 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-20 -end-20 w-96 h-96 rounded-full bg-white opacity-5 blur-3xl"></div>

  <div class="container relative z-10 text-center text-white">

    <h2 class="text-3xl md:text-4xl font-extrabold mb-3 tracking-tight">
      {{ trans('home.newsletter_title') }}
    </h2>
    <p class="text-white mb-10 max-w-md mx-auto text-lg leading-relaxed opacity-75">
      {{ trans('home.newsletter_subtitle') }}
    </p>

    <form id="newsletter-form" class="max-w-lg mx-auto" onsubmit="return false;">

      <div class="flex w-full shadow-xl rounded-full overflow-hidden">
        <input id="newsletter-email"
               type="email"
               required
               placeholder="{{ trans('home.newsletter_placeholder') }}"
               class="flex-1 px-6 py-4 bg-white text-gray-800 border-0 placeholder-gray-400 focus:outline-none text-base">
        <button id="newsletter-btn"
                type="submit"
                onclick="
                  var form = document.getElementById('newsletter-form');
                  var email = document.getElementById('newsletter-email').value;
                  var btn = document.getElementById('newsletter-btn');
                  if (!email) return;
                  btn.disabled = true;
                  salla.newsletter.subscribe(email).then(function() {
                    form.innerHTML = '<p class=\'text-white font-medium py-4\'><i class=\'sicon-check-circle me-2\'></i>{{ trans('home.newsletter_success_message')|default('شكراً! تم تسجيلك بنجاح.') }}</p>';
                  }).catch(function() { btn.disabled = false; });
                "
                class="btn btn--primary px-8 py-4 font-semibold text-base rounded-e-full border-0">
          {{ trans('home.newsletter_subscribe') }}
        </button>
      </div>

    </form>

    <div class="flex flex-wrap justify-center gap-6 mt-10 text-white text-xs opacity-60">
      <span class="flex items-center gap-1.5">
        <i class="sicon-lock"></i>
        {{ trans('home.newsletter_no_spam')|default('لا رسائل مزعجة') }}
      </span>
      <span class="flex items-center gap-1.5">
        <i class="sicon-shield-check"></i>
        {{ trans('home.newsletter_privacy')|default('بياناتك محمية') }}
      </span>
      <span class="flex items-center gap-1.5">
        <i class="sicon-close-circle"></i>
        {{ trans('home.newsletter_unsubscribe')|default('إلغاء الاشتراك في أي وقت') }}
      </span>
    </div>

  </div>
</section>
