{# Newsletter subscription section #}
<section class="newsletter-section bg-souq-primary py-16" data-animate>
  <div class="container text-center text-white">

    <h2 class="text-2xl md:text-3xl font-bold mb-2">{{ trans('home.newsletter_title') }}</h2>
    <p class="text-white/80 mb-8 max-w-md mx-auto">{{ trans('home.newsletter_subtitle') }}</p>

    <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
          x-data="{ email: '', sent: false, loading: false }"
          @submit.prevent="
            loading = true;
            salla.newsletter.subscribe(email)
              .then(() => { sent = true; email = ''; })
              .finally(() => loading = false);
          ">

      <input type="email"
             x-model="email"
             required
             placeholder="{{ trans('home.newsletter_placeholder') }}"
             class="flex-1 rounded-full px-5 py-3 text-souq-text bg-white border-0 focus:ring-2 focus:ring-white focus:outline-none"
             :disabled="sent || loading">

      <button type="submit"
              :disabled="sent || loading"
              class="btn bg-white text-souq-primary hover:bg-white/90 rounded-full px-7 py-3 font-semibold transition-colors disabled:opacity-60 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-souq-primary">
        <span x-show="!sent && !loading">{{ trans('home.newsletter_subscribe') }}</span>
        <span x-show="loading" x-cloak>
          <i class="sicon-refresh animate-spin"></i>
        </span>
        <span x-show="sent" x-cloak>
          <i class="sicon-check me-1"></i>{{ trans('home.newsletter_success') }}
        </span>
      </button>

    </form>
  </div>
</section>
