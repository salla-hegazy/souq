{# Newsletter subscription section #}
<section class="newsletter-section relative overflow-hidden py-20" data-animate>

  {# Gradient background #}
  <div class="absolute inset-0 bg-gradient-to-br from-souq-primary via-souq-primary/90 to-souq-accent/80"></div>
  <div class="pointer-events-none absolute -top-20 -start-20 w-80 h-80 rounded-full bg-white/5 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-20 -end-20 w-96 h-96 rounded-full bg-white/5 blur-3xl"></div>

  <div class="container relative z-10 text-center text-white">

    <div class="badge badge-outline border-white/40 text-white/90 mb-6 px-4 py-3 text-xs tracking-widest uppercase gap-2">
      <i class="sicon-envelope text-souq-accent"></i>
      {{ trans('home.newsletter_badge') ?? 'النشرة البريدية' }}
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold mb-3 tracking-tight">
      {{ trans('home.newsletter_title') }}
    </h2>
    <p class="text-white/75 mb-10 max-w-md mx-auto text-lg leading-relaxed">
      {{ trans('home.newsletter_subtitle') }}
    </p>

    <form class="max-w-lg mx-auto"
          x-data="{ email: '', sent: false, loading: false }"
          @submit.prevent="
            loading = true;
            salla.newsletter.subscribe(email)
              .then(() => { sent = true; email = ''; })
              .finally(() => loading = false);
          ">

      <div class="join w-full shadow-2xl">
        <input type="email"
               x-model="email"
               required
               placeholder="{{ trans('home.newsletter_placeholder') }}"
               class="join-item input input-lg flex-1 w-full bg-white text-souq-text border-0 placeholder:text-souq-text-muted focus:outline-none rounded-s-full"
               :disabled="sent || loading">

        <button type="submit"
                :disabled="sent || loading"
                class="join-item btn btn-secondary btn-lg rounded-e-full px-8 font-semibold border-0 disabled:opacity-60 min-w-[120px]">
          <span x-show="!sent && !loading">{{ trans('home.newsletter_subscribe') }}</span>
          <span x-show="loading" x-cloak>
            <span class="loading loading-spinner loading-sm"></span>
          </span>
          <span x-show="sent" x-cloak class="flex items-center gap-2">
            <i class="sicon-check"></i>{{ trans('home.newsletter_success') }}
          </span>
        </button>
      </div>

      <p x-show="sent" x-cloak
         class="mt-4 text-white/80 text-sm animate-pulse">
        <i class="sicon-check-circle me-1 text-green-300"></i>
        {{ trans('home.newsletter_success_message') ?? 'شكراً! تم تسجيلك بنجاح.' }}
      </p>

    </form>

    {# Trust badges below form #}
    <div class="flex flex-wrap justify-center gap-6 mt-10 text-white/60 text-xs">
      <span class="flex items-center gap-1.5">
        <i class="sicon-lock text-white/50"></i>
        {{ trans('home.newsletter_privacy') ?? 'لا رسائل مزعجة' }}
      </span>
      <span class="flex items-center gap-1.5">
        <i class="sicon-shield-check text-white/50"></i>
        {{ trans('home.newsletter_no_spam') ?? 'بياناتك محمية' }}
      </span>
      <span class="flex items-center gap-1.5">
        <i class="sicon-close-circle text-white/50"></i>
        {{ trans('home.newsletter_unsubscribe') ?? 'إلغاء الاشتراك في أي وقت' }}
      </span>
    </div>

  </div>
</section>
